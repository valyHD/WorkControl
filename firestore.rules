rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }

    match /tools/{toolId} {
      allow read, write: if request.auth != null;
    }

    match /toolEvents/{eventId} {
      allow read, write: if request.auth != null;
    }

    match /vehicles/{vehicleId} {
      allow read, write: if request.auth != null;

      match /positions/{positionId} {
        allow read, write: if request.auth != null;
      }

      match /events/{eventId} {
        allow read, write: if request.auth != null;
      }

      match /commands/{commandId} {
        allow read, write: if request.auth != null;
      }
    }

    match /vehicleEvents/{eventId} {
      allow read, write: if request.auth != null;
    }

    match /projects/{projectId} {
      allow read, write: if request.auth != null;
    }

    match /timesheets/{timesheetId} {
      allow read, write: if request.auth != null;
    }

    match /notifications/{notificationId} {
      allow read, write: if request.auth != null;
    }

    match /notificationRules/{ruleId} {
      allow read, write: if request.auth != null;
    }

    match /systemSettings/{settingId} {
      allow read, write: if request.auth != null;
    }

    match /backupJobs/{jobId} {
      allow read, write: if request.auth != null;
    }

    match /vehicleMaintenanceAlerts/{alertId} {
      allow read, write: if request.auth != null;
    }


    match /maintenanceClients/{clientId} {
      allow read, write: if request.auth != null;

      match /rapoarte/{reportId} {
        allow read, write: if request.auth != null;
      }
    }

    match /maintenanceLifts/{liftId} {
      allow read, write: if request.auth != null;
    }

    match /maintenanceReports/{reportId} {
      allow read, write: if request.auth != null;
    }

    match /rapoarte/{reportId} {
      allow read, write: if request.auth != null;
    }

    match /firmeMentenanta/{brandingId} {
      allow read, write: if request.auth != null;
    }
  }
}
