rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdminUser() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function canControlVehicleGpsVisibility() {
      return isSignedIn() && request.auth.token.email == "ionut.matura23@gmail.com";
    }

    match /users/{userId} {
      allow read, write: if isSignedIn();

      match /pageChangeReads/{readId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    match /tools/{toolId} {
      allow read, write: if isSignedIn();
    }

    match /toolEvents/{eventId} {
      allow read, write: if isSignedIn();
    }

    match /vehicles/{vehicleId} {
      allow read, write: if isSignedIn();

      match /positions/{positionId} {
        allow read, write: if isSignedIn();
      }

      match /positionDays/{dayKey} {
        allow read, write: if isSignedIn();

        match /points/{pointId} {
          allow read, write: if isSignedIn();
        }
      }

      match /diagnosticDays/{dayKey} {
        allow read, write: if isSignedIn();
      }

      match /events/{eventId} {
        allow read, write: if isSignedIn();
      }

      match /commands/{commandId} {
        allow read, write: if isSignedIn();
      }
    }

    match /vehicleEvents/{eventId} {
      allow read, write: if isSignedIn();
    }

    match /vehiclePositionArchives/{archiveId} {
      allow read: if isSignedIn();
      allow write: if isAdminUser();
    }

    match /vehicleMaintenanceAlerts/{alertId} {
      allow read, write: if isSignedIn();
    }

    match /trackerBindings/{imei} {
      allow read, write: if isSignedIn();
    }

    match /unboundTrackerPackets/{packetId} {
      allow read, write: if isSignedIn();
    }

    match /projects/{projectId} {
      allow read, write: if isSignedIn();
    }

    match /timesheets/{timesheetId} {
      allow read, write: if isSignedIn();
    }

    match /expenseDocuments/{expenseId} {
      allow read, write: if isSignedIn();
    }

    match /expenseScanJobs/{jobId} {
      allow read, write: if isSignedIn();
    }

    match /notifications/{notificationId} {
      allow read, write: if isSignedIn();
    }

    match /auditLogs/{auditId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdminUser();
    }

    match /aiCommandLogs/{traceId} {
      allow read: if isAdminUser();
      allow write: if false;
    }

    match /appFeedback/{feedbackId} {
      allow create: if isSignedIn() &&
        request.resource.data.ownerUserId == request.auth.uid &&
        request.resource.data.keys().hasOnly([
          "ownerUserId", "category", "message", "path", "status", "createdAt", "createdAtServer"
        ]) &&
        request.resource.data.category in ["idea", "problem", "usability"] &&
        request.resource.data.message is string &&
        request.resource.data.message.size() >= 5 &&
        request.resource.data.message.size() <= 1500 &&
        request.resource.data.status == "new";
      allow read, update, delete: if isAdminUser();
    }

    match /notificationRules/{ruleId} {
      allow read, write: if isSignedIn();
    }


    match /pushTokens/{tokenId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /systemSettings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() &&
        (settingId != "vehicleGpsVisibility" || canControlVehicleGpsVisibility());
    }

    match /backupJobs/{jobId} {
      allow read, write: if isSignedIn();
    }

    match /maintenanceClients/{clientId} {
      allow read, write: if isSignedIn();

      match /rapoarte/{reportId} {
        allow read, write: if isSignedIn();
      }
    }

    match /maintenanceLifts/{liftId} {
      allow read, write: if isSignedIn();
    }

    match /maintenanceReports/{reportId} {
      allow read, write: if isSignedIn();
    }

    match /maintenancePartOrders/{orderId} {
      allow read, write: if isSignedIn();
    }

    match /rapoarte/{reportId} {
      allow read, write: if isSignedIn();
    }

    match /leaveRequests/{requestId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isSignedIn() && (isAdminUser() || resource.data.userId == request.auth.uid);
    }

    match /leaveBalances/{balanceId} {
      allow read, write: if isSignedIn();
    }

    match /leaveSettings/{settingId} {
      allow read, write: if isSignedIn();
    }

    match /holidays/{holidayId} {
      allow read, write: if isSignedIn();
    }

    match /firmeMentenanta/{brandingId} {
      allow read, write: if isSignedIn();
    }
        match /leaveRequests/{requestId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isSignedIn() && (isAdminUser() || resource.data.userId == request.auth.uid);
    }

    match /leaveBalances/{balanceId} {
      allow read, write: if isSignedIn();
    }

    match /leaveSettings/{settingId} {
      allow read, write: if isSignedIn();
    }

    match /holidays/{holidayId} {
      allow read, write: if isSignedIn();
    }
  }
}
